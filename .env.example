# ============================================
# NusaLingua MVP — Environment Variables
# Copy file ini ke .env dan isi nilai-nilainya
# ============================================

# OpenAI API Key — daftar di https://platform.openai.com
OPENAI_API_KEY=sk-...

# OpenAI model selection
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17

# ============================================
# SUPABASE — Database + Auth
# Daftar di https://supabase.com, buat project baru.
# Ambil credentials di: Project Settings → API
# ============================================

# Database URL (Supabase → Project Settings → Database → Connection string → URI)
DATABASE_URL=postgres://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase Project URL (Project Settings → API → Project URL)
SUPABASE_URL=https://xxxxx.supabase.co

# Anon (public) key — boleh di-expose ke client
SUPABASE_ANON_KEY=eyJhbGciOi...

# Service role key — RAHASIA, hanya di server
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# JWT secret untuk verify token (Project Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=...

# ============================================
# SERVER CONFIG
# ============================================
PORT=3001
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# ============================================
# CLIENT (Vite) — prefix dengan VITE_
# ============================================
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# ===== AI Provider (NEW — chat & streaming) =====
# Pilih: "groq" (free) atau "openai" (paid)
# Kalau kosong, otomatis pakai groq bila GROQ_API_KEY tersedia.
AI_PROVIDER=groq

# Groq — daftar gratis di https://console.groq.com/keys
# Model rekomen: llama-3.3-70b-versatile (cepat, multilingual)
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
